#include<stdio.h>
#include<stdlib.h>

struct Point{int x,y;};

int orientation(struct Point p,struct Point q,struct Point r){
    int val=(q.y-p.y)*(r.x-q.x)-(q.x-p.x)*(r.y-q.y);
    if(val==0)return 0;
    return(val>0)?1:2;
}

int main(){
    struct Point points[]={{1,1},{4,6},{8,1},{0,0},{3,3}};
    int n=5;
    if(n<3)return 0;
    struct Point hull[100];
    int k=0;
    for(int i=0;i<n;i++){
        for(int j=i+1;j<n;j++){
            int pos=0,neg=0;
            for(int l=0;l<n;l++){
                if(l==i||l==j)continue;
                int val=(points[j].x-points[i].x)*(points[l].y-points[i].y)-(points[j].y-points[i].y)*(points[l].x-points[i].x);
                if(val>0)pos++;
                if(val<0)neg++;
            }
            if(pos==0||neg==0){
                hull[k++]=points[i];
                hull[k++]=points[j];
            }
        }
    }
    for(int i=0;i<k-1;i++){
        for(int j=i+1;j<k;j++){
            if(hull[i].x==hull[j].x&&hull[i].y==hull[j].y){
                for(int m=j;m<k-1;m++)hull[m]=hull[m+1];
                k--;
                j--;
            }
        }
    }
    struct Point temp;
    for(int i=0;i<k-1;i++){
        for(int j=i+1;j<k;j++){
            if(hull[i].x>hull[j].x||(hull[i].x==hull[j].x&&hull[i].y>hull[j].y)){
                temp=hull[i];
                hull[i]=hull[j];
                hull[j]=temp;
            }
        }
    }
    printf("Convex Hull: [");
    for(int i=0;i<k;i++){
        printf("(%d, %d)",hull[i].x,hull[i].y);
        if(i!=k-1)printf(", ");
    }
    printf("]");
    return 0;
}

OUTPUT:Convex Hull: [(0, 0), (1, 1), (8, 1), (4, 6)]
