#include<stdio.h>
int count=0;
void merge(int a[],int l,int m,int r){
int n1=m-l+1,n2=r-m;
int L[50],R[50];
for(int i=0;i<n1;i++)L[i]=a[l+i];
for(int j=0;j<n2;j++)R[j]=a[m+1+j];
int i=0,j=0,k=l;
while(i<n1&&j<n2){
count++;
if(L[i]<=R[j])a[k++]=L[i++];
else a[k++]=R[j++];
}
while(i<n1)a[k++]=L[i++];
while(j<n2)a[k++]=R[j++];
}
void mergesort(int a[],int l,int r){
if(l<r){
int m=(l+r)/2;
mergesort(a,l,m);
mergesort(a,m+1,r);
merge(a,l,m,r);
}
}
int main(){
int a[]={12,4,78,23,45,67,89,1};
int n=8;
mergesort(a,0,n-1);
for(int i=0;i<n;i++){
printf("%d",a[i]);
if(i!=n-1)printf(",");
}
printf("\nComparisons:%d",count);
return 0;
}

