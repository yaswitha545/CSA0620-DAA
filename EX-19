
#include<stdio.h>
void print(int a[],int n){
for(int i=0;i<n;i++){
printf("%d",a[i]);
if(i!=n-1)printf(",");
}
printf("\n");
}
int partition(int a[],int l,int r,int n){
int pivot=a[l];
int i=l+1,j=r;
while(1){
while(i<=r&&a[i]<=pivot)i++;
while(a[j]>pivot)j--;
if(i<j){
int t=a[i];a[i]=a[j];a[j]=t;
}
else break;
}
a[l]=a[j];
a[j]=pivot;
print(a,n);
return j;
}
void quicksort(int a[],int l,int r,int n){
if(l<r){
int p=partition(a,l,r,n);
quicksort(a,l,p-1,n);
quicksort(a,p+1,r,n);
}
}
int main(){
int a[]={10,16,8,12,15,6,3,9,5};
int n=9;
quicksort(a,0,n-1,n);
return 0;
}

