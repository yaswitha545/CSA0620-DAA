#include<stdio.h>
int n;
int min;
int best[10];
int cost[10][10];
void swap(int*a,int*b){
int t=*a;*a=*b;*b=t;
}
void perm(int a[],int l){
if(l==n){
int sum=0;
for(int i=0;i<n;i++)sum+=cost[i][a[i]];
if(sum<min){
min=sum;
for(int i=0;i<n;i++)best[i]=a[i];
}
return;
}
for(int i=l;i<n;i++){
swap(&a[l],&a[i]);
perm(a,l+1);
swap(&a[l],&a[i]);
}
}
void solve(){
int a[10];
for(int i=0;i<n;i++)a[i]=i;
min=1000000;
perm(a,0);
printf("Optimal Assignment: ");
for(int i=0;i<n;i++)printf("[(worker %d, task %d)] ",i+1,best[i]+1);
printf("\nTotal Cost: %d\n",min);
}
int main(){
printf("Test Case 1:\n");
n=3;
cost[0][0]=3;cost[0][1]=10;cost[0][2]=7;
cost[1][0]=8;cost[1][1]=5;cost[1][2]=12;
cost[2][0]=4;cost[2][1]=6;cost[2][2]=9;
solve();
printf("Test Case 2:\n");
cost[0][0]=15;cost[0][1]=9;cost[0][2]=4;
cost[1][0]=8;cost[1][1]=7;cost[1][2]=18;
cost[2][0]=6;cost[2][1]=12;cost[2][2]=11;
solve();
return 0;
}

