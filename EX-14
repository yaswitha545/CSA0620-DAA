#include<stdio.h>
int n,capacity;
int weights[10],values[10];
int maxv,bestmask;
int total_value(int mask){
int sum=0;
for(int i=0;i<n;i++)if(mask&(1<<i))sum+=values[i];
return sum;
}
int is_feasible(int mask){
int sum=0;
for(int i=0;i<n;i++)if(mask&(1<<i))sum+=weights[i];
return sum<=capacity;
}
void solve(){
maxv=0;bestmask=0;
for(int mask=0;mask<(1<<n);mask++){
if(is_feasible(mask)){
int v=total_value(mask);
if(v>maxv){maxv=v;bestmask=mask;}
}
}
printf("Optimal Selection: [");
int first=1;
for(int i=0;i<n;i++){
if(bestmask&(1<<i)){
if(!first)printf(", ");
printf("%d",i);
first=0;
}
}
printf("]\nTotal Value: %d\n",maxv);
}
int main(){
printf("Test Case 1:\n");
n=3;
weights[0]=2;weights[1]=3;weights[2]=1;
values[0]=4;values[1]=5;values[2]=3;
capacity=4;
solve();
printf("Test Case 2:\n");
n=4;
weights[0]=1;weights[1]=2;weights[2]=3;weights[3]=4;
values[0]=2;values[1]=4;values[2]=6;values[3]=3;
capacity=6;
solve();
return 0;
}

OUTPUT:
