
#include<stdio.h>
void print(int a[],int n){
for(int i=0;i<n;i++){
printf("%d",a[i]);
if(i!=n-1)printf(",");
}
printf("\n");
}
void quicksort(int a[],int l,int r,int n){
if(l>=r)return;
int i=l,j=r;
int pivot=a[(l+r)/2];
while(i<=j){
while(a[i]<pivot)i++;
while(a[j]>pivot)j--;
if(i<=j){
int t=a[i];a[i]=a[j];a[j]=t;
i++;j--;
}
}
print(a,n);
if(l<j)quicksort(a,l,j,n);
if(i<r)quicksort(a,i,r,n);
}
int main(){
int a[]={19,72,35,46,58,91,22,31};
int n=8;
quicksort(a,0,n-1,n);
return 0;
}

