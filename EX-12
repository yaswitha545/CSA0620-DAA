
#include<stdio.h>
#include<math.h>
int n;
double min;
int best[10];
double x[10],y[10];
double dist(int i,int j){
return sqrt((x[i]-x[j])*(x[i]-x[j])+(y[i]-y[j])*(y[i]-y[j]));
}
void swap(int*a,int*b){
int t=*a;*a=*b;*b=t;
}
void perm(int a[],int l){
if(l==n-1){
double d=0;
d+=dist(0,a[0]);
for(int i=0;i<n-2;i++)d+=dist(a[i],a[i+1]);
d+=dist(a[n-2],0);
if(d<min){
min=d;
for(int i=0;i<n-1;i++)best[i]=a[i];
}
return;
}
for(int i=l;i<n-1;i++){
swap(&a[l],&a[i]);
perm(a,l+1);
swap(&a[l],&a[i]);
}
}
void tsp(){
int a[10];
for(int i=1;i<n;i++)a[i-1]=i;
min=1e9;
perm(a,0);
printf("Shortest Distance: %.15lf\n",min);
printf("Shortest Path: [");
printf("(%.0lf, %.0lf), ",x[0],y[0]);
for(int i=0;i<n-1;i++)printf("(%.0lf, %.0lf), ",x[best[i]],y[best[i]]);
printf("(%.0lf, %.0lf)]\n",x[0],y[0]);
}
int main(){
printf("Test Case 1:\n");
n=4;
x[0]=1;y[0]=2;
x[1]=4;y[1]=5;
x[2]=7;y[2]=1;
x[3]=3;y[3]=6;
tsp();
printf("Test Case 2:\n");
n=5;
x[0]=2;y[0]=4;
x[1]=8;y[1]=1;
x[2]=1;y[2]=7;
x[3]=6;y[3]=3;
x[4]=5;y[4]=9;
tsp();
return 0;
}

